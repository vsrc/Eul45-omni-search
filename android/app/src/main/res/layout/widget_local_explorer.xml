<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_explorer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widget_explorer_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center">

    <LinearLayout
        android:id="@+id/btn_internal"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:id="@+id/widget_explorer_icon_1"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_folder" />
        <TextView android:id="@+id/widget_explorer_text_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Internal"
            android:textColor="@color/widget_text"
            android:textSize="10sp"
            android:singleLine="true"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_downloads"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:id="@+id/widget_explorer_icon_2"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_download" />
        <TextView android:id="@+id/widget_explorer_text_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Down"
            android:textColor="@color/widget_text"
            android:textSize="10sp"
            android:singleLine="true"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_images"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:id="@+id/widget_explorer_icon_3"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_image" />
        <TextView android:id="@+id/widget_explorer_text_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Images"
            android:textColor="@color/widget_text"
            android:textSize="10sp"
            android:singleLine="true"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_documents"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:id="@+id/widget_explorer_icon_4"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_document" />
        <TextView android:id="@+id/widget_explorer_text_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Docs"
            android:textColor="@color/widget_text"
            android:textSize="10sp"
            android:singleLine="true"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_music"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView android:id="@+id/widget_explorer_icon_5"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_music" />
        <TextView android:id="@+id/widget_explorer_text_5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Music"
            android:textColor="@color/widget_text"
            android:textSize="10sp"
            android:singleLine="true"/>
    </LinearLayout>

</LinearLayout>
</FrameLayout>
