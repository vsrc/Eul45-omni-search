<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <!-- Centered Search Capsule with fixed height -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="center">

        <!-- Background Image View of the search capsule -->
        <ImageView
            android:id="@+id/widget_search_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/widget_search_bg_dark" />

        <!-- Interactive Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">

            <!-- OmniSearch Icon (Left) -->
            <ImageView
                android:id="@+id/widget_icon_left"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_widget_search"
                android:layout_marginEnd="12dp"
                android:adjustViewBounds="true" />

            <!-- Search Bar text / clickable area (Center) -->
            <TextView
                android:id="@+id/widget_search_text"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Search PC files..."
                android:textColor="@color/widget_text"
                android:textSize="14sp"
                android:gravity="center_vertical|start"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Toggle Icon (Right) -->
            <ImageView
                android:id="@+id/widget_icon_toggle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="1dp"
                android:src="@drawable/ic_widget_computer"
                android:layout_marginStart="12dp"
                android:adjustViewBounds="true" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
