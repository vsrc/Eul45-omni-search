<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_music_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widget_music_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_bg" />
        
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:orientation="vertical"
        android:gravity="center">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <ImageView
                android:id="@+id/widget_music_art"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_widget_music"
                android:background="#22000000" />
                
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/widget_music_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Not playing"
                    android:textColor="@color/widget_text"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
                    
                <TextView
                    android:id="@+id/widget_music_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="OmniSearch"
                    android:textColor="@color/widget_text"
                    android:alpha="0.7"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="4">
            
            <ImageView
                android:id="@+id/widget_music_favorite"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:src="@drawable/ic_notification_favorite_border"
                android:scaleType="centerInside"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="@color/widget_text" />
                
            <ImageView
                android:id="@+id/widget_music_prev"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:scaleType="centerInside"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="@color/widget_text" />
                
            <ImageView
                android:id="@+id/widget_music_play_pause"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_play"
                android:scaleType="centerInside"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="@color/widget_text" />
                
            <ImageView
                android:id="@+id/widget_music_next"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_next"
                android:scaleType="centerInside"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="@color/widget_text" />
                
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
